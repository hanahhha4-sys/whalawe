# Copy file ini sebagai referensi.
# Jangan upload file ini ke GitHub!
# Set semua variable ini di Railway Dashboard → Variables

# WAJIB diisi:
ARKHAM_KEY=isi_api_key_arkham_kamu_disini
TG_TOKEN=isi_bot_token_telegram_kamu_disini
TG_CHAT_ID=isi_chat_id_telegram_kamu_disini

# OPSIONAL — sudah ada nilai default:
ANTHROPIC_KEY=isi_anthropic_key_untuk_AI_analysis   # kalau mau fitur AI analisis
MIN_PCT=0.3          # minimum % supply kumulatif
MIN_USD=50000        # minimum USD kumulatif ($50K)
MIN_TXS=2            # minimum jumlah transaksi
WINDOW_HOURS=2       # window clustering dalam jam
SCAN_MINUTES=5       # interval scan dalam menit
TX_TYPE=BOTH         # BUY / SELL / BOTH
